# MongoDB Atlas
# Get this from: MongoDB Atlas -> your cluster -> Connect -> Drivers
MONGODB_URI=mongodb+srv://REPLACE_USER:REPLACE_PASSWORD@REPLACE_CLUSTER.mongodb.net/placify?retryWrites=true&w=majority

# Optional: override the database name (defaults to "placify")
# MONGODB_DB_NAME=placify

# JWT secret
PLACIFY_SECRET_KEY=replace-this-with-a-long-random-secret-string

# Server
HOST=127.0.0.1
PORT=5000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# Session token settings
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
# COOKIE_SECURE=false

# OAuth provider credentials
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/oauth/google/callback

GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret
# GITHUB_REDIRECT_URI=http://localhost:5000/api/auth/oauth/github/callback

# Dev options
# UVICORN_RELOAD=true
